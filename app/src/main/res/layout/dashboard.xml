<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7F0"
    android:orientation="vertical">

    <!-- ===== TOP BAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B5E20"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/logo_siramku"
            android:background="@drawable/bg_logo_white"
            android:padding="6dp"
            android:scaleType="fitCenter"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SIRAMKU"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smart Hydroponic System"
                android:textColor="#A5D6A7"
                android:textSize="10sp"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnNotif"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_notification"
            android:background="@drawable/bg_icon_button"
            android:layout_marginEnd="8dp"
            android:padding="6dp"/>

        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_person"
            android:background="@drawable/bg_icon_button"
            android:padding="6dp"/>
    </LinearLayout>

    <!-- ===== SCROLLABLE CONTENT ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== GREETING + HEALTH BANNER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2E7D32"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="26dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selamat pagi, Petani!"
                    android:textColor="#A5D6A7"
                    android:textSize="13sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kebun Anda dalam kondisi baik"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Health Score Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_health_card"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status Kesehatan"
                            android:textColor="#C8E6C9"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvStatusKesehatan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sehat"
                            android:textColor="#69F0AE"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:id="@+id/tvRekomendasi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kondisi optimal untuk pertumbuhan"
                            android:textColor="#A5D6A7"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvSkor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="92"
                            android:textColor="#FFFFFF"
                            android:textSize="36sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Skor"
                            android:textColor="#A5D6A7"
                            android:textSize="10sp"
                            android:background="@drawable/bg_pill_transparent"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ===== WHITE CARD CONTENT ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_rounded_top"
                android:layout_marginTop="-10dp"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Sensor Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sensor Monitoring"
                    android:textColor="#1B5E20"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- Sensor Grid (2x2) -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:layout_marginBottom="18dp">

                    <!-- TDS Card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:background="@drawable/bg_sensor_green"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TDS" android:textColor="#4CAF50" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvTDS"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="850" android:textColor="#1B5E20" android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="ppm · Normal" android:textColor="#4CAF50" android:textSize="11sp"/>
                        <ProgressBar
                            android:id="@+id/progressTDS"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent" android:layout_height="4dp"
                            android:layout_marginTop="8dp"
                            android:progress="72"
                            android:progressTint="#2E7D32"
                            android:progressBackgroundTint="#C8E6C9"/>
                    </LinearLayout>

                    <!-- Level Air Card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:background="@drawable/bg_sensor_blue"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Level Air" android:textColor="#1976D2" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvLevelAir"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="75" android:textColor="#0D47A1" android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="% · Cukup" android:textColor="#1976D2" android:textSize="11sp"/>
                        <ProgressBar
                            android:id="@+id/progressAir"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent" android:layout_height="4dp"
                            android:layout_marginTop="8dp"
                            android:progress="75"
                            android:progressTint="#1976D2"
                            android:progressBackgroundTint="#BBDEFB"/>
                    </LinearLayout>

                    <!-- Suhu Card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:background="@drawable/bg_sensor_amber"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Suhu" android:textColor="#F9A825" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvSuhu"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="24°" android:textColor="#E65100" android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Celsius · Optimal" android:textColor="#F9A825" android:textSize="11sp"/>
                        <ProgressBar
                            android:id="@+id/progressSuhu"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent" android:layout_height="4dp"
                            android:layout_marginTop="8dp"
                            android:progress="55"
                            android:progressTint="#F9A825"
                            android:progressBackgroundTint="#FFECB3"/>
                    </LinearLayout>

                    <!-- pH Card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:background="@drawable/bg_sensor_purple"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="pH Air" android:textColor="#8E24AA" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvPH"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="6.8" android:textColor="#4A148C" android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Nilai · Normal" android:textColor="#8E24AA" android:textSize="11sp"/>
                        <ProgressBar
                            android:id="@+id/progressPH"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent" android:layout_height="4dp"
                            android:layout_marginTop="8dp"
                            android:progress="68"
                            android:progressTint="#8E24AA"
                            android:progressBackgroundTint="#E1BEE7"/>
                    </LinearLayout>

                </GridLayout>

                <!-- Kontrol Pompa Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kontrol Pompa"
                    android:textColor="#1B5E20"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <!-- Pump Control Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pump_card"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Pompa Utama" android:textColor="#1B5E20" android:textSize="13sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Aktif sejak 06:00" android:textColor="#558B2F" android:textSize="11sp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvPompaStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ON"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_status_on"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNyalakan"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="Nyalakan"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            app:backgroundTint="#2E7D32"
                            app:cornerRadius="10dp"
                            app:icon="@drawable/ic_water_drop"
                            app:iconTint="#FFFFFF"
                            app:iconSize="14dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMatikan"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="Matikan"
                            android:textSize="11sp"
                            android:textColor="#558B2F"
                            app:strokeColor="#C5E1A5"
                            app:cornerRadius="10dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnJadwal"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="Jadwal"
                            android:textSize="11sp"
                            android:textColor="#558B2F"
                            app:strokeColor="#C5E1A5"
                            app:cornerRadius="10dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- AI Recommendation -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_recommendation"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Rekomendasi AI"
                        android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvRekomendasiAI"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tambah nutrisi TDS sekitar 50 ppm untuk meningkatkan hasil panen minggu ini."
                        android:textColor="#388E3C" android:textSize="12sp"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp">

            <TextView
                android:id="@+id/tvDashboard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dashboard"
                android:textColor="#2E7D32"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                app:drawableTopCompat="@android:drawable/ic_menu_today"
                android:drawablePadding="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvHistory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Histori"
                android:textColor="#757575"
                android:textSize="12sp"
                android:gravity="center"
                app:drawableTopCompat="@android:drawable/ic_menu_recent_history"
                android:drawablePadding="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvControl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Kontrol"
                android:textColor="#757575"
                android:textSize="12sp"
                android:gravity="center"
                app:drawableTopCompat="@android:drawable/ic_menu_manage"
                android:drawablePadding="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvAccount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Akun"
                android:textColor="#757575"
                android:textSize="12sp"
                android:gravity="center"
                app:drawableTopCompat="@android:drawable/ic_menu_myplaces"
                android:drawablePadding="4dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>