<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7F0"
    android:orientation="vertical">

    <!-- ===== TOP BAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B5E20"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/logo_siramku"
            android:background="@drawable/bg_logo_white"
            android:padding="6dp"
            android:scaleType="fitCenter"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SIRAMKU"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smart Hydroponic System"
                android:textColor="#A5D6A7"
                android:textSize="10sp"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnNotif"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_notification"
            android:background="@drawable/bg_icon_button"
            android:layout_marginEnd="8dp"
            android:padding="6dp"/>  
    </LinearLayout>

    <!-- ===== SCROLLABLE CONTENT ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== GREETING + HEALTH BANNER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2E7D32"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="26dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selamat pagi, Petani!"
                    android:textColor="#A5D6A7"
                    android:textSize="13sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kebun Anda dalam kondisi baik"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Health Score Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_health_card"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status Kesehatan"
                            android:textColor="#C8E6C9"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvStatusKesehatan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sehat"
                            android:textColor="#69F0AE"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:id="@+id/tvRekomendasi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kondisi optimal untuk pertumbuhan"
                            android:textColor="#A5D6A7"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvSkor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="92"
                            android:textColor="#FFFFFF"
                            android:textSize="36sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Skor"
                            android:textColor="#A5D6A7"
                            android:textSize="10sp"
                            android:background="@drawable/bg_pill_transparent"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ===== WHITE CARD CONTENT ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_rounded_top"
                android:layout_marginTop="-10dp"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Sensor Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sensor Monitoring"
                    android:textColor="#1B5E20"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- Sensor Grid (2x2) -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:layout_marginBottom="18dp">

                    <!-- TDS Card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:background="@drawable/bg_sensor_green"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TDS" android:textColor="#4CAF50" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvTDS"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="850" android:textColor="#1B5E20" android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="ppm · Normal" android:textColor="#4CAF50" android:textSize="11sp"/>
                        <ProgressBar
                            android:id="@+id/progressTDS"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent" android:layout_height="4dp"
                            android:layout_marginTop="8dp"
                            android:progress="72"
                            android:progressTint="#2E7D32"
                            android:progressBackgroundTint="#C8E6C9"/>
                    </LinearLayout>

                    <!-- Level Air Card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:background="@drawable/bg_sensor_blue"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Level Air" android:textColor="#1976D2" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvLevelAir"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="75" android:textColor="#0D47A1" android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="% · Cukup" android:textColor="#1976D2" android:textSize="11sp"/>
                        <ProgressBar
                            android:id="@+id/progressAir"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent" android:layout_height="4dp"
                            android:layout_marginTop="8dp"
                            android:progress="75"
                            android:progressTint="#1976D2"
                            android:progressBackgroundTint="#BBDEFB"/>
                    </LinearLayout>
                </GridLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daftar Pompa"
                    android:textColor="#1B5E20"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp"/>

                <!-- ===== POMPA NUTRISI ===== -->
                <LinearLayout
                    android:id="@+id/cardPompaNutrisi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pump_card_green"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_water_drop"
                            android:background="@drawable/bg_icon_green_light"
                            android:padding="8dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pompa Nutrisi"
                                android:textColor="#1B5E20"
                                android:textSize="13sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvJadwalNutrisi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="08:00 - 08:15"
                                android:textColor="#558B2F"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvStatusNutrisi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tidak Aktif"
                            android:textColor="#C62828"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_badge_inactive"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_info_row"
                        android:orientation="vertical"
                        android:padding="10dp"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Mode Operasi"
                                android:textColor="#757575"
                                android:textSize="11sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Otomatis"
                                android:textColor="#2E7D32"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_badge_mode"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Durasi"
                                android:textColor="#757575"
                                android:textSize="11sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="15 menit"
                                android:textColor="#424242"
                                android:textSize="11sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNyalakanNutrisi"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="Nyalakan"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            app:backgroundTint="#2E7D32"
                            app:cornerRadius="10dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEditNutrisi"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:text="Edit Jadwal"
                            android:textSize="11sp"
                            android:textColor="#558B2F"
                            app:strokeColor="#C5E1A5"
                            app:cornerRadius="10dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== POMPA AIR ===== -->
                <LinearLayout
                    android:id="@+id/cardPompaAir"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pump_card_green"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_shower"
                            android:background="@drawable/bg_icon_blue_light"
                            android:padding="8dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pompa Air"
                                android:textColor="#0D47A1"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvJadwalAir"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12:00 - 12:20"
                                android:textColor="#1565C0"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvStatusAir"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tidak Aktif"
                            android:textColor="#C62828"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_badge_inactive"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_info_row"
                        android:orientation="vertical"
                        android:padding="10dp"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Mode Operasi"
                                android:textColor="#757575"
                                android:textSize="11sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Otomatis"
                                android:textColor="#2E7D32"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_badge_mode"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Durasi"
                                android:textColor="#757575"
                                android:textSize="11sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="20 menit"
                                android:textColor="#424242"
                                android:textSize="11sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNyalakanAir"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="Nyalakan"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            app:backgroundTint="#2E7D32"
                            app:cornerRadius="10dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEditAir"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:text="Edit Jadwal"
                            android:textSize="11sp"
                            android:textColor="#558B2F"
                            app:strokeColor="#BBDEFB"
                            app:cornerRadius="10dp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp">

            <TextView
                android:id="@+id/tvDashboard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dashboard"
                android:textColor="#2E7D32"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                app:drawableTopCompat="@android:drawable/ic_menu_today"
                android:drawablePadding="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvHistory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Histori"
                android:textColor="#757575"
                android:textSize="12sp"
                android:gravity="center"
                app:drawableTopCompat="@android:drawable/ic_menu_recent_history"
                android:drawablePadding="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvControl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Kontrol"
                android:textColor="#757575"
                android:textSize="12sp"
                android:gravity="center"
                app:drawableTopCompat="@android:drawable/ic_menu_manage"
                android:drawablePadding="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tvAccount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Akun"
                android:textColor="#757575"
                android:textSize="12sp"
                android:gravity="center"
                app:drawableTopCompat="@android:drawable/ic_menu_myplaces"
                android:drawablePadding="4dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>