<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#SIRAMKU"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#2E7D32" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Smart Hydroponic System"
            android:textSize="14sp"
            android:textColor="#757575" />
    </LinearLayout>

    <!-- ScrollView untuk konten -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Judul Halaman dan Jumlah Notifikasi -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Notifikasi"
                    android:textColor="#333333"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 notifikasi baru"
                    android:textColor="#2E7D32"
                    android:textSize="14sp"
                    android:background="#E8F5E9"
                    android:padding="8dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Tab Filter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tabSemua"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Semua (8)"
                    android:textColor="#2E7D32"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="#E8F5E9"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tabBelumDibaca"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Belum Dibaca (2)"
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="#FFFFFF"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Daftar Notifikasi -->

            <!-- Notifikasi 1 - pH Level Rendah -->
            <androidx.cardview.widget.CardView
                android:id="@+id/notifikasi1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#FFF9C4"> <!-- Warna kuning untuk notifikasi baru -->

                    <!-- Header Notifikasi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="pH Level Rendah"
                            android:textColor="#333333"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Baru"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:background="#F44336"
                            android:padding="4dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp" />
                    </LinearLayout>

                    <!-- Pesan Notifikasi -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="pH turun ke 5.8, pompa pH Up diaktifkan otomatis"
                        android:textColor="#757575"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <!-- Waktu -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 menit yang lalu"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp" />

                    <!-- Tombol Aksi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/btnTandaiDibaca1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tandai Dibaca"
                            android:textColor="#2E7D32"
                            android:textSize="14sp"
                            android:padding="8dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="?android:attr/selectableItemBackground" />

                        <TextView
                            android:id="@+id/btnHapus1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hapus"
                            android:textColor="#F44336"
                            android:textSize="14sp"
                            android:padding="8dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="?android:attr/selectableItemBackground"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Notifikasi 2 - Pompa Nutrisi Aktif -->
            <androidx.cardview.widget.CardView
                android:id="@+id/notifikasi2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#FFF9C4"> <!-- Warna kuning untuk notifikasi baru -->

                    <!-- Header Notifikasi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Pompa Nutrisi Aktif"
                            android:textColor="#333333"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Baru"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:background="#F44336"
                            android:padding="4dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp" />
                    </LinearLayout>

                    <!-- Pesan Notifikasi -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pompa nutrisi berhasil diaktifkan untuk 15 menit"
                        android:textColor="#757575"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <!-- Waktu -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30 menit yang lalu"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp" />

                    <!-- Tombol Aksi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/btnTandaiDibaca2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tandai Dibaca"
                            android:textColor="#2E7D32"
                            android:textSize="14sp"
                            android:padding="8dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="?android:attr/selectableItemBackground" />

                        <TextView
                            android:id="@+id/btnHapus2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hapus"
                            android:textColor="#F44336"
                            android:textSize="14sp"
                            android:padding="8dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="?android:attr/selectableItemBackground"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Notifikasi 3 - Level Air Rendah (Notifikasi Lama) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/notifikasi3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#FFFFFF"> <!-- Warna putih untuk notifikasi lama -->

                    <!-- Header Notifikasi -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Level Air Rendah"
                        android:textColor="#333333"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Pesan Notifikasi -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Level air di bawah 30%, segera isi ulang tangki"
                        android:textColor="#757575"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <!-- Waktu -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 jam yang lalu"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp" />

                    <!-- Tombol Aksi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/btnHapus3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hapus"
                            android:textColor="#F44336"
                            android:textSize="14sp"
                            android:padding="8dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="?android:attr/selectableItemBackground" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Notifikasi 4 - Contoh Notifikasi Lama Lainnya -->
            <androidx.cardview.widget.CardView
                android:id="@+id/notifikasi4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:visibility="gone"> <!-- Visibility gone untuk contoh, nanti diatur di Java -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Suhu Terlalu Tinggi"
                        android:textColor="#333333"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Suhu mencapai 32°C, kipas pendingin diaktifkan"
                        android:textColor="#757575"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 jam yang lalu"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/btnTandaiDibaca4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tandai Dibaca"
                            android:textColor="#2E7D32"
                            android:textSize="14sp"
                            android:padding="8dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="?android:attr/selectableItemBackground" />

                        <TextView
                            android:id="@+id/btnHapus4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hapus"
                            android:textColor="#F44336"
                            android:textSize="14sp"
                            android:padding="8dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="?android:attr/selectableItemBackground"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvDashboard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Dashboard"
            android:textColor="#757575"
            android:textSize="14sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvHistory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Histori"
            android:textColor="#757575"
            android:textSize="14sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvControl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Kontrol"
            android:textColor="#757575"
            android:textSize="14sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvNotifications"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Notifikasi"
            android:textColor="#2E7D32"
            android:textSize="14sp"
            android:gravity="center"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAccount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Akun"
            android:textColor="#757575"
            android:textSize="14sp"
            android:gravity="center" />
    </LinearLayout>
</LinearLayout>