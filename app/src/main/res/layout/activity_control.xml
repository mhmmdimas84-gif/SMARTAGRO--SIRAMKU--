<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7F0"
    android:orientation="vertical">

    <!-- ===== TOP BAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B5E20"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/logo_siramku"
            android:background="@drawable/bg_logo_white"
            android:padding="6dp"
            android:scaleType="fitCenter"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SIRAMKU"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smart Hydroponic System"
                android:textColor="#A5D6A7"
                android:textSize="10sp"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnNotif"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_notification"
            android:background="@drawable/bg_icon_button"
            android:layout_marginEnd="8dp"
            android:padding="6dp"/>

    </LinearLayout>

    <!-- ===== HEADER KONTROL ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2E7D32"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="26dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kontrol Pompa"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kelola jadwal &amp; operasi pompa"
                    android:textColor="#A5D6A7"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ===== SCROLLABLE PUMP LIST ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_rounded_top"
                android:layout_marginTop="-10dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daftar Pompa"
                    android:textColor="#1B5E20"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp"/>

                <!-- ===== POMPA NUTRISI ===== -->
                <LinearLayout
                    android:id="@+id/cardPompaNutrisi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pump_card_green"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_water_drop"
                            android:background="@drawable/bg_icon_green_light"
                            android:padding="8dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pompa Nutrisi"
                                android:textColor="#1B5E20"
                                android:textSize="13sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvJadwalNutrisi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="08:00 - 08:15"
                                android:textColor="#558B2F"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvStatusNutrisi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tidak Aktif"
                            android:textColor="#C62828"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_badge_inactive"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_info_row"
                        android:orientation="vertical"
                        android:padding="10dp"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Mode Operasi"
                                android:textColor="#757575"
                                android:textSize="11sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Otomatis"
                                android:textColor="#2E7D32"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_badge_mode"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Durasi"
                                android:textColor="#757575"
                                android:textSize="11sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="15 menit"
                                android:textColor="#424242"
                                android:textSize="11sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNyalakanNutrisi"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="Nyalakan"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            app:backgroundTint="#2E7D32"
                            app:cornerRadius="10dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEditNutrisi"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:text="Edit Jadwal"
                            android:textSize="11sp"
                            android:textColor="#558B2F"
                            app:strokeColor="#C5E1A5"
                            app:cornerRadius="10dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== POMPA AIR ===== -->
                <LinearLayout
                    android:id="@+id/cardPompaAir"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pump_card_green"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_shower"
                            android:background="@drawable/bg_icon_blue_light"
                            android:padding="8dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pompa Air"
                                android:textColor="#0D47A1"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvJadwalAir"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12:00 - 12:20"
                                android:textColor="#1565C0"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvStatusAir"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tidak Aktif"
                            android:textColor="#C62828"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_badge_inactive"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_info_row"
                        android:orientation="vertical"
                        android:padding="10dp"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Mode Operasi"
                                android:textColor="#757575"
                                android:textSize="11sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Otomatis"
                                android:textColor="#2E7D32"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_badge_mode"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Durasi"
                                android:textColor="#757575"
                                android:textSize="11sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="20 menit"
                                android:textColor="#424242"
                                android:textSize="11sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNyalakanAir"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="Nyalakan"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            app:backgroundTint="#2E7D32"
                            app:cornerRadius="10dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEditAir"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:text="Edit Jadwal"
                            android:textSize="11sp"
                            android:textColor="#558B2F"
                            app:strokeColor="#BBDEFB"
                            app:cornerRadius="10dp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ===== BOTTOM NAVIGATION ===== -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="8dp">

            <TextView
                android:id="@+id/tvDashboard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dashboard"
                android:textColor="#757575"
                android:textSize="12sp"
                android:gravity="center"
                app:drawableTopCompat="@android:drawable/ic_menu_today"
                android:drawablePadding="4dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tvHistory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Histori"
                android:textColor="#757575"
                android:textSize="12sp"
                android:gravity="center"
                app:drawableTopCompat="@android:drawable/ic_menu_recent_history"
                android:drawablePadding="4dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tvControl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Kontrol"
                android:textColor="#2E7D32"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                app:drawableTopCompat="@android:drawable/ic_menu_manage"
                android:drawablePadding="4dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tvAccount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Akun"
                android:textColor="#757575"
                android:textSize="12sp"
                android:gravity="center"
                app:drawableTopCompat="@android:drawable/ic_menu_myplaces"
                android:drawablePadding="4dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>